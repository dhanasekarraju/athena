# --- PostgreSQL ---
POSTGRES_USER=athena
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=athena

# --- Backend ---
DATABASE_URL=postgresql://athena:change_me_strong_password@localhost:5432/athena
JWT_SECRET=change_me_at_least_32_chars_long_secret
JWT_REFRESH_SECRET=change_me_another_32_chars_long_secret
CORS_ORIGIN=*
AI_ENGINE_URL=http://localhost:8000

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- AI Engine (optional integrations) ---
WHALE_ALERT_API_KEY=

# --- Mobile app (build-time) ---
API_BASE_URL=http://localhost:4000
WS_BASE_URL=ws://localhost:4000

# --- Cautious Delta auto-trader (options only) ---
# Start with PAPER_TRADING=true. Set false only after dry-runs look correct.
AUTONOMOUS_TRADING=false
PAPER_TRADING=true
DELTA_API_KEY=
DELTA_API_SECRET=
DELTA_BASE_URL=https://api.india.delta.exchange
MAX_ORDER_INR=1000
MAX_OPEN_EXPOSURE_INR=2000
MIN_SIGNAL_CONFIDENCE=55
AUTONOMOUS_SYMBOLS=BTC,ETH
SL_FRACTION=0.4
TP1_FRACTION=0.5
BOT_POLL_MS=15000
USD_INR_RATE=85
PAPER_BALANCE_INR=10000
