generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  trades        Trade[]
  watchlist     WatchlistItem[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Signal {
  id              String    @id @default(uuid())
  symbol          String
  timeframe       String
  direction       String // BUY_CALL | BUY_PUT | HOLD
  confidence      Float
  riskLevel       String
  entryLow        Float
  entryHigh       Float
  target1         Float
  target2         Float
  stopLoss        Float
  reasons         Json
  factorBreakdown Json
  price           Float
  // Deribit options contract + premium plan (nullable for HOLD / unavailable)
  instrumentName  String?
  optionType      String? // call | put
  strike          Float?
  expiry          DateTime?
  daysToExpiry    Float?
  premiumUsd      Float?
  premiumCoin     Float?
  markIv          Float?
  premiumEntryLow Float?
  premiumEntryHigh Float?
  premiumTarget1  Float?
  premiumTarget2  Float?
  premiumStopLoss Float?
  optionMeta      Json?
  createdAt       DateTime  @default(now())

  @@index([symbol, timeframe, createdAt])
}

model Trade {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol       String
  direction    String // BUY_CALL | BUY_PUT
  entryPrice   Float
  exitPrice    Float?
  quantity     Float
  stopLoss     Float?
  target1      Float?
  target2      Float?
  status       String    @default("OPEN") // OPEN | CLOSED
  pnl          Float?
  notes        String?
  openedAt     DateTime  @default(now())
  closedAt     DateTime?

  @@index([userId, status])
}

/// Autonomous bot positions (Delta options). Separate from manual journal trades.
model BotPosition {
  id             String    @id @default(uuid())
  exchange       String    @default("delta")
  productId      Int
  productSymbol  String
  underlying     String
  direction      String // BUY_CALL | BUY_PUT
  size           Float
  entryPremium   Float
  stopLoss       Float
  takeProfit1    Float
  status         String    @default("OPEN") // OPEN | CLOSED
  paper          Boolean   @default(true)
  entryOrderId   String?
  exitOrderId    String?
  exitPremium    Float?
  exitReason     String?
  realizedPnl    Float?
  signalSnapshot Json?
  openedAt       DateTime  @default(now())
  closedAt       DateTime?

  @@index([status, openedAt])
  @@index([productSymbol, status])
}

/// Singleton runtime config editable from the mobile Settings UI (id = "default").
model BotConfig {
  id                 String   @id @default("default")
  autonomousEnabled  Boolean  @default(false)
  paperTrading       Boolean  @default(true)
  maxOrderInr        Float    @default(1000)
  maxOpenExposureInr Float    @default(2000)
  minConfidence      Float    @default(55)
  symbols            String   @default("BTC,ETH")
  slFraction         Float    @default(0.4)
  tp1Fraction        Float    @default(0.5)
  skipHighRisk       Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}

model WatchlistItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  createdAt DateTime @default(now())

  @@unique([userId, symbol])
}

model NewsItem {
  id            String   @id @default(uuid())
  title         String
  source        String
  url           String
  sentiment     String // Bullish | Bearish | Neutral
  sentimentScore Float
  publishedAt   DateTime
  createdAt     DateTime @default(now())

  @@index([publishedAt])
}
